// ALTIVAX FamilyPay — Schéma Prisma V2
// RÈGLES IMMUABLES : authorizations, transactions, audit_logs → INSERT ONLY (triggers PostgreSQL)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ═══════════════════════════════════════════════════════════════════════════
// ENUMS
// ═══════════════════════════════════════════════════════════════════════════

enum UserRole {
  SPONSOR
  BENEFICIARY
  MERCHANT
  ADMIN
}

enum AllocationCategory {
  PHARMACY
  FOOD
  CLOTHING
  EDUCATION
  LEISURE
  GENERAL
}

enum AllocationStatus {
  ACTIVE
  PAUSED
  EXPIRED
  EXHAUSTED
}

enum MerchantKycStatus {
  PENDING_PSP
  APPROVED
  REJECTED
}

enum MerchantActivationStatus {
  INACTIVE
  ACTIVE
  SUSPENDED
}

enum AuthorizationStatus {
  APPROVED
  REJECTED
  PENDING_REVIEW
}

enum TransactionStatus {
  COMPLETED
  FAILED
}

enum OtpPurpose {
  VERIFY_PHONE
  SIGNUP
  LOGIN
}

// ═══════════════════════════════════════════════════════════════════════════
// USER — socle commun des 4 rôles
// ═══════════════════════════════════════════════════════════════════════════

model User {
  id            String   @id @default(uuid())
  phone         String   @unique
  email         String?  @unique
  firstName     String?
  lastName      String?
  role          UserRole
  cndpConsentAt DateTime
  isVerified    Boolean  @default(false)
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  sponsor     Sponsor?
  beneficiary Beneficiary?
  merchant    Merchant?

  @@index([phone])
  @@map("users")
}

// ═══════════════════════════════════════════════════════════════════════════
// SPONSOR — crée et finance les allocations
// ═══════════════════════════════════════════════════════════════════════════

model Sponsor {
  id        String   @id @default(uuid())
  userId    String   @unique
  user      User     @relation(fields: [userId], references: [id])
  createdAt DateTime @default(now())

  beneficiaries Beneficiary[]
  allocations   Allocation[]
  transactions  Transaction[]

  @@map("sponsors")
}

// ═══════════════════════════════════════════════════════════════════════════
// BENEFICIARY — dépense dans les allocations du sponsor
// ═══════════════════════════════════════════════════════════════════════════

model Beneficiary {
  id                String    @id @default(uuid())
  userId            String    @unique
  user              User      @relation(fields: [userId], references: [id])
  sponsorId         String
  sponsor           Sponsor   @relation(fields: [sponsorId], references: [id])
  isMinor           Boolean   @default(false)
  parentalConsentAt DateTime?
  isActive          Boolean   @default(true)
  createdAt         DateTime  @default(now())

  allocations    Allocation[]
  authorizations Authorization[]

  @@index([sponsorId])
  @@map("beneficiaries")
}

// ═══════════════════════════════════════════════════════════════════════════
// MERCHANT — réseau marchand partenaire validé par ALTIVAX
// ═══════════════════════════════════════════════════════════════════════════

model Merchant {
  id                   String                   @id @default(uuid())
  userId               String                   @unique
  user                 User                     @relation(fields: [userId], references: [id])
  businessName         String
  category             AllocationCategory
  address              String
  city                 String
  phone                String
  kycStatus            MerchantKycStatus        @default(PENDING_PSP)
  activationStatus     MerchantActivationStatus @default(INACTIVE)
  pspMerchantReference String?
  createdAt            DateTime                 @default(now())
  updatedAt            DateTime                 @updatedAt

  authorizations Authorization[]
  qrCodes        QrCode[]
  transactions   Transaction[]

  @@map("merchants")
}

// ═══════════════════════════════════════════════════════════════════════════
// ALLOCATION — enveloppe virtuelle par catégorie | remainingAmount >= 0 (CHECK DB)
// ═══════════════════════════════════════════════════════════════════════════

model Allocation {
  id              String             @id @default(uuid())
  sponsorId       String
  sponsor         Sponsor            @relation(fields: [sponsorId], references: [id])
  beneficiaryId   String
  beneficiary     Beneficiary        @relation(fields: [beneficiaryId], references: [id])
  category        AllocationCategory
  limitAmount     Decimal            @db.Decimal(12, 2)
  remainingAmount Decimal            @db.Decimal(12, 2)
  status          AllocationStatus   @default(ACTIVE)
  expiresAt       DateTime?
  renewalPeriod   String?
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt

  authorizations Authorization[]

  @@index([beneficiaryId])
  @@index([sponsorId])
  @@map("allocations")
}

// ═══════════════════════════════════════════════════════════════════════════
// AUTHORIZATION — INSERT ONLY (trigger prevent_update_on_authorizations)
// ═══════════════════════════════════════════════════════════════════════════

model Authorization {
  id              String              @id @default(uuid())
  allocationId    String
  allocation      Allocation          @relation(fields: [allocationId], references: [id])
  beneficiaryId   String
  beneficiary     Beneficiary         @relation(fields: [beneficiaryId], references: [id])
  merchantId      String
  merchant        Merchant            @relation(fields: [merchantId], references: [id])
  amount          Decimal             @db.Decimal(12, 2)
  status          AuthorizationStatus
  rejectionReason String?
  fraudScore      Int                 @default(0)
  createdAt       DateTime            @default(now())

  transaction Transaction?
  qrCode      QrCode?

  @@index([beneficiaryId])
  @@index([allocationId])
  @@index([createdAt])
  @@map("authorizations")
}

// ═══════════════════════════════════════════════════════════════════════════
// TRANSACTION — INSERT ONLY (trigger prevent_update_on_transactions)
// ═══════════════════════════════════════════════════════════════════════════

model Transaction {
  id               String            @id @default(uuid())
  authorizationId  String            @unique
  authorization    Authorization     @relation(fields: [authorizationId], references: [id])
  sponsorId        String
  sponsor          Sponsor           @relation(fields: [sponsorId], references: [id])
  merchantId       String
  merchant         Merchant          @relation(fields: [merchantId], references: [id])
  amount           Decimal           @db.Decimal(12, 2)
  pspTransactionId String
  status           TransactionStatus
  createdAt        DateTime          @default(now())

  @@index([sponsorId])
  @@index([merchantId])
  @@map("transactions")
}

// ═══════════════════════════════════════════════════════════════════════════
// QR CODE — TTL 60s fixe | usage unique (Redis nonce + usedAt)
// NE JAMAIS augmenter TTL sans autorisation explicite
// ═══════════════════════════════════════════════════════════════════════════

model QrCode {
  id              String             @id @default(uuid())
  merchantId      String
  merchant        Merchant           @relation(fields: [merchantId], references: [id])
  category        AllocationCategory
  amount          Decimal            @db.Decimal(12, 2)
  token           String             @unique
  expiresAt       DateTime
  usedAt          DateTime?
  authorizationId String?            @unique
  authorization   Authorization?     @relation(fields: [authorizationId], references: [id])
  createdAt       DateTime           @default(now())

  @@index([merchantId])
  @@index([token])
  @@map("qr_codes")
}

// ═══════════════════════════════════════════════════════════════════════════
// OTP CODE — hash bcrypt | expiration 5 min | usage unique
// ═══════════════════════════════════════════════════════════════════════════

model OtpCode {
  id        String     @id @default(uuid())
  phone     String
  purpose   OtpPurpose
  codeHash  String
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime   @default(now())

  @@index([phone])
  @@map("otp_codes")
}

// ═══════════════════════════════════════════════════════════════════════════
// AUDIT LOG — INSERT ONLY (trigger prevent_update_on_audit_logs)
// ═══════════════════════════════════════════════════════════════════════════

model AuditLog {
  id         String   @id @default(uuid())
  actorId    String?
  action     String
  entityType String
  entityId   String
  metadata   Json     @default("{}")
  createdAt  DateTime @default(now())

  @@index([entityId])
  @@index([actorId])
  @@map("audit_logs")
}
