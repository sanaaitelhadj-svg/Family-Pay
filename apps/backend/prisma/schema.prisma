// ALTIVAX FamilyPay — Schéma Prisma V2
// RÈGLES IMMUABLES : authorizations, transactions, audit_logs → INSERT ONLY (triggers PostgreSQL)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ═══════════════════════════════════════════════════════════════════════════
// ENUMS
// ═══════════════════════════════════════════════════════════════════════════

enum UserRole {
  SPONSOR
  BENEFICIARY
  MERCHANT
  ADMIN
}

enum AllocationCategory {
  PHARMACY
  FOOD
  CLOTHING
  EDUCATION
  LEISURE
  GENERAL
}

enum AllocationStatus {
  ACTIVE
  PAUSED
  EXPIRED
  EXHAUSTED
}

enum MerchantKycStatus {
  PENDING_PSP
  APPROVED
  REJECTED
}

enum MerchantActivationStatus {
  INACTIVE
  ACTIVE
  SUSPENDED
}

enum AuthorizationStatus {
  APPROVED
  REJECTED
  PENDING_REVIEW
}

enum TransactionStatus {
  COMPLETED
  FAILED
}

enum OtpPurpose {
  VERIFY_PHONE
  SIGNUP
  LOGIN
}

// ═══════════════════════════════════════════════════════════════════════════
// USER — socle commun des 4 rôles
// ═══════════════════════════════════════════════════════════════════════════

model User {
  id            String   @id @default(uuid())
  phone         String   @unique
  email         String?  @unique
  password      String?
  firstName     String?
  lastName      String?
  role          UserRole
  cndpConsentAt DateTime
  isVerified    Boolean  @default(false)
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  sponsor     Sponsor?
  beneficiary Beneficiary?
  merchant    Merchant?

  @@index([phone])
  adminRoleId    String?   @db.VarChar(30)
  adminRole      AdminRole? @relation(fields: [adminRoleId], references: [id])

  auditLogs      AuditLog[] @relation("AuditLogAdmin")
  adminSessions      AdminSession[]     @relation("AdminSessions")
  impersonationsAsSuperAdmin ImpersonationLog[] @relation("ImpersonationBySuperAdmin")

  @@map("users")
}

// ═══════════════════════════════════════════════════════════════════════════
// SPONSOR — crée et finance les allocations
// ═══════════════════════════════════════════════════════════════════════════

model Sponsor {
  id        String   @id @default(uuid())
  userId    String   @unique
  user      User     @relation(fields: [userId], references: [id])
  pspCustomerReference String?
  maskedCardReference  String?
  createdAt            DateTime @default(now())

  beneficiaries Beneficiary[]
  allocations   Allocation[]
  transactions  Transaction[]
  commissions   Commission[]

  @@map("sponsors")
}

// ═══════════════════════════════════════════════════════════════════════════
// BENEFICIARY — dépense dans les allocations du sponsor
// ═══════════════════════════════════════════════════════════════════════════

model Beneficiary {
  id                String    @id @default(uuid())
  userId            String    @unique
  user              User      @relation(fields: [userId], references: [id])
  sponsorId         String
  sponsor           Sponsor   @relation(fields: [sponsorId], references: [id])
  dateOfBirth       DateTime?
  isMinor           Boolean   @default(false)
  parentalConsentAt DateTime?
  relationship      String?
  profilePhoto      String?
  isActive          Boolean   @default(true)
  createdAt         DateTime  @default(now())

  allocations    Allocation[]
  authorizations Authorization[]

  @@index([sponsorId])
  @@map("beneficiaries")
}

// ═══════════════════════════════════════════════════════════════════════════
// MERCHANT — réseau marchand partenaire validé par ALTIVAX
// ═══════════════════════════════════════════════════════════════════════════

model Merchant {
  id                   String                   @id @default(uuid())
  userId               String                   @unique
  user                 User                     @relation(fields: [userId], references: [id])
  businessName         String
  category             AllocationCategory
  address              String
  city                 String
  phone                String
  email                String?
  kycStatus            MerchantKycStatus        @default(PENDING_PSP)
  activationStatus     MerchantActivationStatus @default(INACTIVE)
  pspMerchantReference String?
  // Légal
  registrationNumber   String?
  iceNumber            String?
  taxId                String?
  fiscalId             String?
  cinRepresentant      String?
  // Bancaire
  rib                  String?
  attestationBancaire  Boolean   @default(false)
  // Physique
  gpsLat               Float?
  gpsLng               Float?
  photos               Json?
  // Contacts
  contactAdmin         Json?
  contactFinance       Json?
  contactOps           Json?
  contactLegal         Json?
  // Business
  riskLevel            String?
  allowedProducts      Json?
  businessHours        Json?
  // Commission
  contractUrl          String?
  commissionType       String    @default("TRANSACTION_PERCENTAGE")
  commissionRate       Decimal?  @db.Decimal(6, 4)
  // Contractuel
  cguSignedAt          DateTime?
  cguVersion           String?
  cguClauses           Json?
  createdAt            DateTime                 @default(now())
  updatedAt            DateTime                 @updatedAt

  authorizations Authorization[]
  qrCodes        QrCode[]
  transactions   Transaction[]
  commissions    Commission[]

  @@map("merchants")
}

// ═══════════════════════════════════════════════════════════════════════════
// ALLOCATION — enveloppe virtuelle par catégorie | remainingAmount >= 0 (CHECK DB)
// ═══════════════════════════════════════════════════════════════════════════

model Allocation {
  id              String             @id @default(uuid())
  sponsorId       String
  sponsor         Sponsor            @relation(fields: [sponsorId], references: [id])
  beneficiaryId   String
  beneficiary     Beneficiary        @relation(fields: [beneficiaryId], references: [id])
  category        AllocationCategory
  limitAmount     Decimal            @db.Decimal(12, 2)
  remainingAmount Decimal            @db.Decimal(12, 2)
  status          AllocationStatus   @default(ACTIVE)
  expiresAt       DateTime?
  renewalPeriod   String?
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt

  authorizations Authorization[]

  @@index([beneficiaryId])
  @@index([sponsorId])
  @@map("allocations")
}

// ═══════════════════════════════════════════════════════════════════════════
// AUTHORIZATION — INSERT ONLY (trigger prevent_update_on_authorizations)
// ═══════════════════════════════════════════════════════════════════════════

model Authorization {
  id              String              @id @default(uuid())
  allocationId    String
  allocation      Allocation          @relation(fields: [allocationId], references: [id])
  beneficiaryId   String
  beneficiary     Beneficiary         @relation(fields: [beneficiaryId], references: [id])
  merchantId      String
  merchant        Merchant            @relation(fields: [merchantId], references: [id])
  amount          Decimal             @db.Decimal(12, 2)
  status          AuthorizationStatus
  rejectionReason String?
  fraudScore      Int                 @default(0)
  createdAt       DateTime            @default(now())

  transaction Transaction?
  qrCode      QrCode?

  @@index([beneficiaryId])
  @@index([allocationId])
  @@index([createdAt])
  @@map("authorizations")
}

// ═══════════════════════════════════════════════════════════════════════════
// TRANSACTION — INSERT ONLY (trigger prevent_update_on_transactions)
// ═══════════════════════════════════════════════════════════════════════════

model Transaction {
  id               String            @id @default(uuid())
  authorizationId  String            @unique
  authorization    Authorization     @relation(fields: [authorizationId], references: [id])
  sponsorId        String
  sponsor          Sponsor           @relation(fields: [sponsorId], references: [id])
  merchantId       String
  merchant         Merchant          @relation(fields: [merchantId], references: [id])
  amount           Decimal           @db.Decimal(12, 2)
  pspTransactionId String
  status           TransactionStatus
  createdAt        DateTime          @default(now())

  @@index([sponsorId])
  @@index([merchantId])
  commission    Commission?

  @@map("transactions")
}

// ═══════════════════════════════════════════════════════════════════════════
// QR CODE — TTL 60s fixe | usage unique (Redis nonce + usedAt)
// NE JAMAIS augmenter TTL sans autorisation explicite
// ═══════════════════════════════════════════════════════════════════════════

model QrCode {
  id              String             @id @default(uuid())
  merchantId      String
  merchant        Merchant           @relation(fields: [merchantId], references: [id])
  category        AllocationCategory
  amount          Decimal            @db.Decimal(12, 2)
  token           String             @unique
  expiresAt       DateTime
  usedAt          DateTime?
  authorizationId String?            @unique
  authorization   Authorization?     @relation(fields: [authorizationId], references: [id])
  createdAt       DateTime           @default(now())

  @@index([merchantId])
  @@index([token])
  @@map("qr_codes")
}

// ═══════════════════════════════════════════════════════════════════════════
// OTP CODE — hash bcrypt | expiration 5 min | usage unique
// ═══════════════════════════════════════════════════════════════════════════

model OtpCode {
  id        String     @id @default(uuid())
  phone     String
  purpose   OtpPurpose
  codeHash  String
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime   @default(now())

  @@index([phone])
  @@map("otp_codes")
}

// ═══════════════════════════════════════════════════════════════════════════
// AUDIT LOG — INSERT ONLY (trigger prevent_update_on_audit_logs)
// ═══════════════════════════════════════════════════════════════════════════

model AuditLog {
  id             String   @id @default(cuid())
  actorId        String?
  actorRole      String?
  admin          User?    @relation("AuditLogAdmin", fields: [actorId], references: [id])
  action         String
  result         String   @default("SUCCESS")
  entityType     String
  entityId       String
  previousData   Json?
  newData        Json?
  metadata       Json?
  ipAddress      String?
  sessionId      String?
  deviceInfo     String?
  organizationScope String?
  createdAt      DateTime @default(now())

  @@index([actorId])
  @@index([entityId])
  @@index([action])
  @@index([createdAt])
  @@map("audit_logs")
}

// ═══════════════════════════════════════════════════════════════════════════
// COMMISSION — générée automatiquement par transaction complétée
// ═══════════════════════════════════════════════════════════════════════════

model Commission {
  id            String      @id @default(uuid())
  transactionId String      @unique
  transaction   Transaction @relation(fields: [transactionId], references: [id])
  merchantId    String
  merchant      Merchant    @relation(fields: [merchantId], references: [id])
  sponsorId     String
  sponsor       Sponsor     @relation(fields: [sponsorId], references: [id])
  amount        Decimal     @db.Decimal(12, 2)
  rate          Decimal     @db.Decimal(6, 4)
  commissionType String
  status        String      @default("PENDING")
  createdAt     DateTime    @default(now())

  @@map("commissions")
}

// ═══════════════════════════════════════════════════════════════════════════
// SUBSCRIPTION — abonnement sponsor ou marchand
// ═══════════════════════════════════════════════════════════════════════════

model Subscription {
  id         String   @id @default(uuid())
  entityType String
  entityId   String
  plan       String
  amount     Decimal  @db.Decimal(12, 2)
  startDate  DateTime
  endDate    DateTime
  status     String   @default("ACTIVE")
  notes      String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  planId         String?
  subscriptionPlan SubscriptionPlan? @relation(fields: [planId], references: [id])

  @@map("subscriptions")
}

model SubscriptionPlan {
  id             String         @id @default(cuid())
  name           String
  description    String?
  price          Decimal        @db.Decimal(10, 2)
  durationMonths Int
  features       Json?
  isActive       Boolean        @default(true)
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  subscriptions  Subscription[]

  @@map("subscription_plans")
}

// ═══════════════════════════════════════════════════════════════════════════════
// ADMIN ROLES — RBAC
// ═══════════════════════════════════════════════════════════════════════════════
model AdminRole {
  id          String   @id @default(cuid())
  name        String   @unique
  description String?
  permissions Json
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt


  users          User[]

  @@map("admin_roles")
}

// ═══════════════════════════════════════════════════════════════════════════════
// ADMIN SESSIONS
// ═══════════════════════════════════════════════════════════════════════════════
model AdminSession {
  id             String    @id @default(cuid())
  adminId        String
  admin          User      @relation("AdminSessions", fields: [adminId], references: [id])
  ipAddress      String?
  userAgent      String?
  deviceInfo     String?
  status         String    @default("ACTIVE")   // ACTIVE | EXPIRED | REVOKED
  loginAt        DateTime  @default(now())
  lastActivityAt DateTime  @default(now())
  expiresAt      DateTime?
  revokedAt      DateTime?
  revokedById    String?

  @@index([adminId])
  @@index([status])
  @@map("admin_sessions")
}

// ═══════════════════════════════════════════════════════════════════════════════
// IMPERSONATION LOGS
// ═══════════════════════════════════════════════════════════════════════════════
model ImpersonationLog {
  id                 String    @id @default(cuid())
  superAdminId       String
  superAdmin         User      @relation("ImpersonationBySuperAdmin", fields: [superAdminId], references: [id])
  impersonatedUserId String
  reason             String?
  startedAt          DateTime  @default(now())
  endedAt            DateTime?

  @@map("impersonation_logs")
}
