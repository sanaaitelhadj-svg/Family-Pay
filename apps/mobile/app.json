{
  "expo": {
    "name": "FamilyPay",
    "slug": "familypay",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "resizeMode": "contain",
      "backgroundColor": "#1B4FD8",
      "image": "./assets/splash.png"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.altivax.familypay"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#1B4FD8",
        "foregroundImage": "./assets/adaptive-icon.png"
      },
      "package": "com.altivax.familypay",
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "plugins": [
      "expo-router",
      [
        "expo-camera",
        {
          "cameraPermission": "FamilyPay utilise la caméra pour scanner les QR codes de paiement."
        }
      ],
      "@react-native-community/datetimepicker"
    ],
    "scheme": "familypay",
    "experiments": {
      "typedRoutes": true
    },
    "icon": "./assets/icon.png",
    "extra": {
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "8d57d9f4-1d5d-4bf3-a6c8-6e97efedbc76"
      }
    },
    "owner": "sana-aitelhadj"
  }
}
