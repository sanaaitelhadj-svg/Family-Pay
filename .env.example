# ============================================================
# ALTIVAX FamilyPay — Variables d'environnement
# Copier ce fichier en .env et remplir TOUTES les valeurs
# NE JAMAIS committer le fichier .env
# ============================================================

# ── NODE ─────────────────────────────────────────────────────
NODE_ENV=development
PORT=4000
LOG_LEVEL=info

# ── BASE DE DONNÉES POSTGRESQL ───────────────────────────────
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=familypay
POSTGRES_USER=familypay
POSTGRES_PASSWORD=CHANGE_ME_strong_password_here

# URL complète Prisma (construite automatiquement par Docker Compose)
DATABASE_URL=postgresql://familypay:CHANGE_ME_strong_password_here@localhost:5432/familypay

# ── REDIS ────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=CHANGE_ME_redis_password_here

# ── JWT / SÉCURITÉ ───────────────────────────────────────────
# Générer avec : node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=CHANGE_ME_generate_64_bytes_hex
JWT_REFRESH_SECRET=CHANGE_ME_generate_64_bytes_hex_different
# IMPORTANT : QR_SECRET doit être DIFFÉRENT de JWT_SECRET
QR_SECRET=CHANGE_ME_generate_64_bytes_hex_different_from_jwt

# ── MINIO (stockage fichiers KYC) ────────────────────────────
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_USE_SSL=false
MINIO_ROOT_USER=familypay
MINIO_ROOT_PASSWORD=CHANGE_ME_minio_password_here
MINIO_BUCKET_KYC=familypay-kyc
MINIO_BUCKET_PARTNERS=familypay-partners

# ── PAIEMENT CMI (Sprint 7) ──────────────────────────────────
CMI_API_KEY=
CMI_MERCHANT_ID=
CMI_STORE_KEY=
CMI_BASE_URL=https://payment.cmi.co.ma
CMI_SANDBOX_URL=https://testpayment.cmi.co.ma

# ── NOTIFICATIONS PUSH FIREBASE ──────────────────────────────
FCM_SERVER_KEY=
FCM_PROJECT_ID=
FIREBASE_SERVICE_ACCOUNT_PATH=./firebase-service-account.json

# ── SMS (2FA) ─────────────────────────────────────────────────
# Twilio (recommandé)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
# Alternative : OVH SMS
OVH_SMS_SERVICE_NAME=
OVH_SMS_SENDER=FamilyPay

# ── EMAIL ─────────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=noreply@altivax.com

# ── CORS ──────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:3001,http://localhost:3002,http://localhost:3003

# ── LIMITES MÉTIER ────────────────────────────────────────────
# NE PAS MODIFIER sans autorisation explicite
QR_TTL_SECONDS=60
MAX_TRANSACTION_AMOUNT_MAD=5000
KYC_MAX_FILE_SIZE_MB=10
