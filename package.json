{
  "name": "familypay",
  "private": true,
  "version": "0.1.0",
  "description": "ALTIVAX FamilyPay — Portefeuille prépayé multi-enseignes",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "test:ci": "turbo run test --no-cache",
    "type-check": "turbo run type-check",
    "clean": "turbo run clean && rm -rf node_modules",
    "backup": "bash scripts/backup.sh",
    "db:migrate": "npm run db:migrate --workspace=apps/backend",
    "db:studio": "npm run db:studio --workspace=apps/backend",
    "db:reset": "npm run db:reset --workspace=apps/backend"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^8.18.0",
    "@typescript-eslint/parser": "^8.18.0",
    "docx": "^9.6.1",
    "eslint": "^9.17.0",
    "prettier": "^3.4.2",
    "turbo": "^2.3.3",
    "typescript": "^5.7.2"
  },
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  }
}
